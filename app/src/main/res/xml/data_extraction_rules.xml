<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup/transfer rules. We opt out of cloud/device-transfer backups entirely:
  the app's local DB is a cache of the Google Sheet and can be rebuilt by running a sync.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>

<?xml version="1.0" encoding="utf-8"?>
<!-- Inline edit dialog for one family slot (fm2/fm3/fm4). Called from
     MemberDetailFragment when the user taps Edit or + Add family member. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/screen_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/familyName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/family_dialog_name"
            android:inputType="textPersonName" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/family_dialog_relation"
            android:textColor="@color/brand_grey"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/familyRelation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/familyMobile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="@string/family_dialog_mobile"
            android:inputType="phone" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/familyWaSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/family_dialog_wa_switch" />

        <TextView
            android:id="@+id/familyError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/brand_red"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
